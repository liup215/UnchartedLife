[sub_resource type="Shader" id="Shader_circle_frame"]
code = "shader_type canvas_item;

void fragment() {
	vec2 center = vec2(0.5, 0.5);
	float dist = distance(UV, center);
	float radius = 0.45;
	// Invert the mask - show black outside the circle
	float alpha = smoothstep(radius - 0.01, radius, dist);
	COLOR.a = alpha;
}"

